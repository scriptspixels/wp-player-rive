# WordPress Plugin .gitignore

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE / Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
*.code-workspace

# PHP / JS tooling
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.cache
composer.phar
vendor/
node_modules/

# Build / Distribution
*.zip
*.tar.gz
build/
dist/
release/
.cache/

# Testing
.phpunit.result.cache
coverage/
.nyc_output/

# Environment / Config
.env
.env.local
.env.*.local
wp-config.php
wp-config-local.php

# Temporary Files
*.tmp
*.temp
*.bak
*.backup
*.old

# WordPress (full-site or nested checkouts)
wp-content/uploads/
wp-content/upgrade/
wp-content/backup-db/
wp-content/advanced-cache.php
wp-content/wp-cache-config.php
wp-content/cache/
wp-content/debug.log

# Rive runtime source (regenerate rive-wasm.js with scripts/generate-rive-wasm-js.sh)
assets/lib/rive.wasm
